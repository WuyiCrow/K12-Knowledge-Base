{
  "subject": "数学",
  "grade_range": "高一-高三",
  "version": "1.0.0",
  "knowledge_points": [
    {
      "id": "math_001",
      "title": "函数的概念与基本性质",
      "category": "函数",
      "grade": "高一",
      "difficulty": 3,
      "description": "理解函数的定义、定义域、值域的概念，掌握函数的单调性、奇偶性、周期性等基本性质，能够判断和证明函数的性质。",
      "key_concepts": [
        "定义域",
        "值域",
        "单调性",
        "奇偶性",
        "周期性",
        "映射"
      ],
      "formulas": [
        "y = f(x)",
        "f(-x) = f(x)（偶函数）",
        "f(-x) = -f(x)（奇函数）"
      ],
      "examples": [
        {
          "problem": "判断f(x)=x²的奇偶性",
          "solution": "f(-x)=(-x)²=x²=f(x)，所以f(x)是偶函数"
        },
        {
          "problem": "求f(x)=√(x-1)的定义域",
          "solution": "需x-1≥0，即x≥1，定义域为[1,+∞)"
        }
      ],
      "common_mistakes": [
        "忽略定义域的限制条件",
        "混淆奇偶性与对称性",
        "单调性证明时缺少任意性说明"
      ],
      "related_points": [
        "math_002",
        "math_003"
      ]
    },
    {
      "id": "math_002",
      "title": "指数函数与对数函数",
      "category": "函数",
      "grade": "高一",
      "difficulty": 3,
      "description": "掌握指数函数y=aˣ(a>0且a≠1)和对数函数y=log_a(x)的图像特征、单调性及运算法则。",
      "key_concepts": [
        "指数运算",
        "对数运算",
        "换底公式",
        "图像变换"
      ],
      "formulas": [
        "y = aˣ",
        "y = log_a(x)",
        "log_a(MN) = log_a(M) + log_a(N)",
        "log_a(M/N) = log_a(M) - log_a(N)",
        "log_a(Mⁿ) = n·log_a(M)"
      ],
      "examples": [
        {
          "problem": "计算log₂8 + log₂4",
          "solution": "log₂8 + log₂4 = log₂(8×4) = log₂32 = 5"
        },
        {
          "problem": "已知2ˣ=5，求x",
          "solution": "x = log₂5"
        }
      ],
      "common_mistakes": [
        "对数运算中混淆乘除与加减",
        "忽略底数a>0且a≠1的条件",
        "指数函数图像过(0,1)和对数函数图像过(1,0)记混"
      ],
      "related_points": [
        "math_001",
        "math_003"
      ]
    },
    {
