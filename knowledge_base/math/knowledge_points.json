      "title": "三角函数与三角恒等变换",
      "category": "三角函数",
      "grade": "高一",
      "difficulty": 4,
      "description": "掌握正弦、余弦、正切函数的定义、图像和性质，熟练运用和差角公式、二倍角公式进行三角恒等变换。",
      "key_concepts": [
        "弧度制",
        "三角函数定义",
        "诱导公式",
        "和差角公式",
        "二倍角公式",
        "辅助角公式"
      ],
      "formulas": [
        "sin²α + cos²α = 1",
        "sin(α±β) = sinαcosβ ± cosαsinβ",
        "cos(α±β) = cosαcosβ ∓ sinαsinβ",
        "sin2α = 2sinαcosα",
        "cos2α = cos²α - sin²α"
      ],
      "examples": [
        {
          "problem": "化简sin²α + cos²(30°-α)",
          "solution": "利用cos(30°-α)展开后合并化简"
        },
        {
          "problem": "求y=2sin(x+π/6)的周期和振幅",
          "solution": "周期T=2π，振幅A=2"
        }
      ],
      "common_mistakes": [
        "诱导公式'奇变偶不变，符号看象限'使用错误",
        "二倍角公式的逆用不熟练",
        "辅助角公式中φ的值计算错误"
      ],
      "related_points": [
        "math_001",
        "math_004"
      ]
    },
    {
      "id": "math_004",
      "title": "数列与求和方法",
      "category": "数列",
      "grade": "高二",
      "difficulty": 4,
      "description": "掌握等差数列、等比数列的通项公式和前n项和公式，能够运用裂项法、错位相减法等方法求和。",
      "key_concepts": [
        "等差数列",
        "等比数列",
        "通项公式",
        "前n项和",
        "裂项求和",
        "错位相减"
      ],
      "formulas": [
        "aₙ = a₁ + (n-1)d",
        "Sₙ = na₁ + n(n-1)d/2",
        "aₙ = a₁·qⁿ⁻¹",
        "Sₙ = a₁(1-qⁿ)/(1-q)（q≠1）"
      ],
      "examples": [
        {
          "problem": "等差数列{aₙ}中，a₁=2，d=3，求S₂₀",
          "solution": "S₂₀ = 20×2 + 20×19×3/2 = 40 + 570 = 610"
        },
        {
          "problem": "求和：1/(1×2) + 1/(2×3) + ... + 1/(n(n+1))",
          "solution": "裂项：1/(k(k+1)) = 1/k - 1/(k+1)，Sₙ = 1 - 1/(n+1) = n/(n+1)"
        }
      ],
      "common_mistakes": [
        "等比数列求和时忽略q=1的特殊情况",
        "错位相减法运算过程出错",
        "裂项后符号判断错误"
      ],
      "related_points": [
        "math_005",
        "math_006"
      ]
    },
    {
      "id": "math_005",
      "title": "不等式与线性规划",
      "category": "不等式",
      "grade": "高一",
      "difficulty": 3,
      "description": "掌握一元二次不等式的解法，理解基本不等式a+b≥2√(ab)的应用条件，了解简单的线性规划问题。",
      "key_concepts": [
        "一元二次不等式",
        "基本不等式",
        "均值不等式",
        "线性规划",
        "可行域"
      ],
      "formulas": [
        "a + b ≥ 2√(ab)（a,b>0）",
        "当a=b时取等号"
      ],
      "examples": [
        {
          "problem": "求x+1/x的最小值(x>0)",
          "solution": "由基本不等式：x + 1/x ≥ 2√(x·1/x) = 2，当x=1时取等号"
        },
        {
          "problem": "解不等式x²-5x+6<0",
          "solution": "(x-2)(x-3)<0，解集为(2,3)"
        }
      ],
      "common_mistakes": [
        "使用基本不等式时忘记验证等号成立条件",
        "二次不等式开口方向判断错误",
        "线性规划中目标函数几何意义理解不到位"
      ],
      "related_points": [
        "math_001",
        "math_004"
      ]
