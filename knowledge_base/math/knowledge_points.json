        "x²/a² - y²/b² = 1（双曲线）",
        "y² = 2px（抛物线）",
        "e = c/a",
        "b² = a² - c²（椭圆）",
        "b² = c² - a²（双曲线）"
      ],
      "examples": [
        {
          "problem": "椭圆x²/4 + y² = 1的离心率",
