{
  "subject": "物理",
  "grade_range": "高一-高三",
  "version": "1.0.0",
  "knowledge_points": [
    {
      "id": "phy_001",
      "title": "匀变速直线运动",
      "category": "力学",
      "grade": "高一",
      "difficulty": 3,
      "description": "掌握匀变速直线运动的基本公式，理解速度-时间图像的物理意义，能够灵活运用公式解决追及、相遇等问题。",
      "key_concepts": [
        "加速度",
        "速度公式",
        "位移公式",
        "速度-位移关系",
        "v-t图像",
        "自由落体"
      ],
      "formulas": [
        "v = v₀ + at",
        "x = v₀t + ½at²",
        "v² - v₀² = 2ax",
        "x = (v₀+v)t/2"
      ],
      "examples": [
        {
          "problem": "物体从静止开始以2m/s²加速，5秒后的速度和位移",
          "solution": "v=at=2×5=10m/s, x=½at²=½×2×25=25m"
        },
        {
          "problem": "汽车以20m/s刹车，加速度为-4m/s²，求刹车距离",
          "solution": "0-400=2×(-4)×x, x=50m"
        }
      ],
      "common_mistakes": [
        "刹车问题中忘记判断物体是否已停止",
        "位移的方向与正方向混淆",
        "v-t图像中面积的正负号判断错误"
      ],
      "related_points": [
        "phy_002",
        "phy_003"
      ]
    },
    {
      "id": "phy_002",
      "title": "牛顿运动定律",
      "category": "力学",
      "grade": "高一",
      "difficulty": 4,
      "description": "深入理解牛顿三大运动定律，掌握受力分析方法，能够运用牛顿第二定律解决连接体、斜面等经典问题。",
      "key_concepts": [
        "惯性",
        "力的合成与分解",
        "牛顿第二定律",
        "超重与失重",
        "连接体问题",
        "受力分析"
      ],
      "formulas": [
        "F = ma",
        "F₁₂ = -F₂₁（牛顿第三定律）",
        "F合 = ma"
      ],
      "examples": [
        {
          "problem": "质量2kg的物体受水平力10N作用，求加速度（无摩擦）",
          "solution": "a = F/m = 10/2 = 5 m/s²"
        },
        {
          "problem": "电梯加速上升时人的视重变化",
          "solution": "N = m(g+a) > mg，超重"
        }
      ],
      "common_mistakes": [
        "受力分析遗漏力（如摩擦力方向判断错误）",
        "连接体问题中整体法与隔离法选择不当",
        "混淆作用力反作用力与平衡力"
      ],
      "related_points": [
        "phy_001",
        "phy_003"
      ]
    },
    {
      "id": "phy_003",
      "title": "动能定理与机械能守恒",
      "category": "能量",
      "grade": "高一",
      "difficulty": 4,
      "description": "理解功和能的概念，掌握动能定理的应用方法，理解机械能守恒定律的条件和应用。",
      "key_concepts": [
        "功",
        "功率",
        "动能",
        "重力势能",
        "弹性势能",
        "动能定理",
        "机械能守恒",
        "功能关系"
      ],
      "formulas": [
        "W = Fxcosθ",
        "P = W/t = Fv",
        "Eₖ = ½mv²",
        "Eₚ = mgh",
        "W合 = ΔEₖ",
        "Eₖ₁ + Eₚ₁ = Eₖ₂ + Eₚ₂（守恒条件）"
      ],
      "examples": [
        {
          "problem": "质量1kg小球从5m高处自由落下，着地速度",
          "solution": "mgh=½mv², v=√(2gh)=√(2×10×5)=10m/s"
        },
        {
          "problem": "汽车额定功率启动的最大速度条件",
          "solution": "当牵引力等于阻力时速度最大：P=fv_max"
        }
      ],
      "common_mistakes": [
        "机械能守恒条件判断不准确（只有重力/弹力做功）",
        "功的正负号判断错误",
        "动能定理中合外力做功与分力做功混淆"
      ],
      "related_points": [
        "phy_001",
        "phy_002",
        "phy_004"
      ]
    },
    {
      "id": "phy_004",
      "title": "动量守恒定律",
      "category": "动量",
      "grade": "高二",
      "difficulty": 4,
      "description": "理解动量和冲量的概念，掌握动量定理和动量守恒定律的应用条件，能处理碰撞、反冲等问题。",
      "key_concepts": [
        "动量",
        "冲量",
        "动量定理",
        "动量守恒",
        "弹性碰撞",
        "完全非弹性碰撞"
      ],
      "formulas": [
        "p = mv",
        "I = Ft",
        "Ft = Δp = mv - mv₀",
        "m₁v₁ + m₂v₂ = m₁v₁' + m₂v₂'（守恒条件）"
      ],
      "examples": [
        {
          "problem": "子弹射入木块的完全非弹性碰撞，求共同速度",
          "solution": "mv₀ = (m+M)v, v = mv₀/(m+M)"
        },
        {
          "problem": "两球弹性正碰后速度",
          "solution": "联立动量守恒和动能守恒方程求解"
        }
      ],
      "common_mistakes": [
        "动量守恒条件的矢量性（某方向守恒）",
        "碰撞中动能不守恒的判断",
        "动量方向取正负号混乱"
      ],
      "related_points": [
        "phy_003"
      ]
    },
    {
      "id": "phy_005",
      "title": "电场与库仑定律",
      "category": "电磁学",
      "grade": "高二",
      "difficulty": 4,
      "description": "理解电荷守恒、库仑定律，掌握电场强度、电势、电势能等概念及其关系，能处理带电粒子在电场中的运动问题。",
      "key_concepts": [
        "电荷守恒",
        "库仑定律",
        "电场强度",
        "电场线",
        "等势面",
        "电势差",
        "电势能",
        "电容器"
      ],
      "formulas": [
        "F = kq₁q₂/r²",
        "E = F/q",
        "E = U/d（匀强电场）",
        "W = qU",
        "Eₚ = qφ"
      ],
      "examples": [
        {
          "problem": "两个等量异号点电荷连线中点的电场强度",
          "solution": "两个电荷在中点产生的电场方向相同，E=2kq/(d/2)²=8kq/d²"
        },
        {
          "problem": "带电粒子在匀强电场中加速",
          "solution": "qU=½mv²，v=√(2qU/m)"
        }
      ],
      "common_mistakes": [
        "电场强度与电势的关系理解不清",
        "电场力做功与电势能变化符号关系搞混",
        "电容器中插入介质后各量变化分析错误"
      ],
      "related_points": [
        "phy_006"
      ]
    },
    {
      "id": "phy_006",
      "title": "恒定电流与欧姆定律",
      "category": "电磁学",
      "grade": "高二",
      "difficulty": 3,
      "description": "掌握欧姆定律、电阻定律，理解电动势和内阻的概念，能分析含容电路和电路的动态变化。",
      "key_concepts": [
        "欧姆定律",
        "电阻定律",
        "串并联电路",
        "电动势",
        "内阻",
        "闭合电路欧姆定律",
        "电功率"
      ],
      "formulas": [
        "U = IR",
        "R = ρL/S",
        "ε = U + Ir",
        "P = UI = I²R = U²/R"
      ],
      "examples": [
        {
          "problem": "电动势12V、内阻1Ω的电源外接5Ω电阻，求电流",
          "solution": "I = ε/(R+r) = 12/(5+1) = 2A"
        },
        {
          "problem": "两个电阻R₁=6Ω和R₂=3Ω并联的总电阻",
          "solution": "1/R = 1/6 + 1/3 = 1/2, R = 2Ω"
        }
      ],
      "common_mistakes": [
        "内外电压之和等于电动势的关系理解不透彻",
        "电路动态分析中局部→整体→局部的逻辑链断裂",
        "电功率与热功率的区别（纯电阻与非纯电阻）"
      ],
      "related_points": [
        "phy_005"
      ]
    },
    {
      "id": "phy_007",
      "title": "磁场与安培力",
      "category": "电磁学",
      "grade": "高二",
      "difficulty": 4,
      "description": "理解磁感应强度的概念，掌握安培力和洛伦兹力的计算及方向判断（左手定则），能分析带电粒子在磁场中的圆周运动。",
      "key_concepts": [
        "磁感应强度",
        "安培力",
        "洛伦兹力",
        "左手定则",
        "带电粒子圆周运动",
        "回旋加速器"
      ],
      "formulas": [
        "F = BILsinθ（安培力）",
        "f = qvBsinθ（洛伦兹力）",
        "r = mv/(qB)（回旋半径）",
        "T = 2πm/(qB)（周期）"
      ],
      "examples": [
        {
          "problem": "质子以v=10⁶m/s垂直射入B=0.1T的匀强磁场，求回旋半径",
          "solution": "r=mv/(qB)=1.67×10⁻²⁷×10⁶/(1.6×10⁻¹⁹×0.1)≈0.104m"
        },
        {
          "problem": "通电导线在磁场中的安培力方向判断",
          "solution": "左手定则：磁力线穿手心，四指指电流方向，大拇指指力的方向"
        }
      ],
      "common_mistakes": [
        "左手定则与右手定则混淆",
        "洛伦兹力不做功但改变速度方向的理解不到位",
        "回旋半径和周期公式中m、q对应错误"
      ],
      "related_points": [
        "phy_005",
        "phy_008"
      ]
    },
